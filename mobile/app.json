{
  "expo": {
    "name": "Checked",
    "slug": "checklist",
    "version": "0.4.1",
    "orientation": "portrait",
    "icon": "./src/assets/images/icon.png",
    "scheme": "checked",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "githubUrl": "https://github.com/kriteshtimsina/checked",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.kriteshtimsina.checklist",
      "infoPlist": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": true,
          "NSExceptionDomains": {
            "localhost": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "127.0.0.1": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            },
            "192.168.0.0": {
              "NSExceptionAllowsInsecureHTTPLoads": true
            }
          }
        }
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./src/assets/images/icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.kriteshtimsina.checklist",
      "targetSdkVersion": 35,
      "compileSdkVersion": 35,
      "buildToolsVersion": "35.0.0",
      "playStoreUrl": "https://play.google.com/store/apps/details?id=com.kriteshtimsina.checklist"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./src/assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-splash-screen",
        {
          "image": "./src/assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FDF8F2",
          "dark": {
            "backgroundColor": "#0F0F11"
          }
        }
      ],
      [
        "@howincodes/expo-dynamic-app-icon",
        {
          "forest": {
            "ios": "./src/assets/images/icon.png",
            "android": "./src/assets/images/icon.png"
          },
          "sandy": {
            "ios": "./src/assets/images/icon-1.png",
            "android": "./src/assets/images/icon-1.png"
          },
          "tomato": {
            "ios": "./src/assets/images/icon-2.png",
            "android": "./src/assets/images/icon-2.png"
          },
          "lavender": {
            "ios": "./src/assets/images/icon-3.png",
            "android": "./src/assets/images/icon-3.png"
          }
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "ca9c1110-f505-463a-b8cf-71546edb93c9"
      }
    }
  }
}
